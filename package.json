{
  "name": "radeon-voice-skill-foundry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c red,cyan \"tsx watch server/index.ts\" \"vite\"",
    "build": "npm run typecheck && vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:optimization": "node scripts/benchmark_optimizations.mjs",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name radeon-voice-skill-foundry --branch main"
  },
  "dependencies": {
    "busboy": "1.6.0",
    "express": "5.2.1",
    "jszip": "3.10.1",
    "lucide-react": "0.468.0",
    "motion": "^12.23.12",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "3.24.1"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.27.7",
    "@rollup/rollup-linux-x64-gnu": "4.62.2"
  },
  "devDependencies": {
    "@types/busboy": "1.5.4",
    "@types/express": "5.0.5",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "9.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
