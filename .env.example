# OpenAI-compatible endpoint hosted on Radeon Cloud.
RADEON_OPENAI_BASE_URL=https://example-radeon-endpoint/v1
RADEON_API_KEY=
RADEON_MODEL=Qwen/Qwen3-8B

# Runtime metadata shown in the proof bundle.
RADEON_ASR_MODEL=Qwen/Qwen3-ASR-0.6B
RADEON_GPU_NAME=AMD Radeon GPU
ROCM_VERSION=ROCm 7.x
RADEON_ASR_RTF=
RADEON_ASR_X_REALTIME=
RADEON_ASR_PEAK_VRAM_GIB=

# Local API port. Defaults to 8791.
PORT=8791
HOST=127.0.0.1
