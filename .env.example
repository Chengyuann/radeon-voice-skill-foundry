# OpenAI-compatible endpoint hosted on Radeon Cloud.
RADEON_OPENAI_BASE_URL=https://example-radeon-endpoint/v1
RADEON_API_KEY=
RADEON_MODEL=Qwen/Qwen3-8B

# Runtime metadata shown in the proof bundle.
RADEON_ASR_MODEL=Qwen/Qwen3-ASR-0.6B
RADEON_ASR_BASE_URL=http://127.0.0.1:8001
RADEON_GPU_NAME=AMD Radeon GPU
ROCM_VERSION=ROCm 7.x
RADEON_ASR_RTF=
RADEON_ASR_X_REALTIME=
RADEON_ASR_PEAK_VRAM_GIB=

# Local API port. Defaults to 8791.
PORT=8791
HOST=127.0.0.1

# Optional shared secret used between Cloudflare Pages Functions and the
# Radeon-hosted API. Leave unset for ordinary localhost development.
RVSF_API_TOKEN=

# Cloudflare Pages production gateway. RADEON_API_ORIGIN is a fallback only;
# production resolves the active Quick Tunnel origin from RVSF_ORIGIN_REGISTRY.
RADEON_API_ORIGIN=https://example.trycloudflare.com
RVSF_ORIGIN_RECOVERY_TOKEN=
